  <link rel="manifest" href='data:application/manifest+json,{
    "name":"Balonmano Pro",
    "short_name":"Balonmano",
    "display":"standalone",
    "background_color":"#0A192F",
    "theme_color":"#0A192F",
    "start_url":"./"
  }'>

  <style>

    :root{
      --bg:#0A192F;
      --card:rgba(17,34,64,0.75);
      --cyan:#64FFDA;
      --text:#CCD6F6;
      --muted:#8892B0;
      --danger:#FF6B6B;
      --border:rgba(100,255,218,0.18);
    }

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    html{
      scroll-behavior:smooth;
    }

    body{
      background:
      radial-gradient(circle at top,#112240 0%,#0A192F 55%);
      color:var(--text);
      font-family:'Inter',sans-serif;
      overflow-x:hidden;
      line-height:1.6;
    }

    h1,h2,h3{
      font-family:'Montserrat',sans-serif;
      text-transform:uppercase;
      letter-spacing:1px;
    }

    section{
      max-width:1200px;
      margin:auto;
      padding:5rem 1.5rem;

      opacity:0;
      transform:translateY(20px);

      transition:
      opacity .8s ease,
      transform .8s ease;
    }

    section.visible{
      opacity:1;
      transform:translateY(0);
    }

    /* HERO */

    .hero{
      min-height:100vh;

      display:flex;
      flex-direction:column;
      justify-content:center;
      align-items:center;

      text-align:center;
      gap:1.5rem;

      padding:2rem;
    }

    .hero h1{
      font-size:clamp(3rem,8vw,6rem);
      color:var(--cyan);

      text-shadow:
      0 0 20px rgba(100,255,218,0.25);
    }

    .hero p{
      max-width:700px;
      color:var(--muted);
      font-size:1.15rem;
    }

    .cta-btn{
      padding:1rem 2rem;

      border-radius:18px;
      border:1px solid var(--cyan);

      background:transparent;
      color:var(--cyan);

      font-weight:700;
      cursor:pointer;

      transition:.3s ease;

      min-width:44px;
      min-height:44px;
    }

    .cta-btn:hover{
      transform:translateY(-4px);

      box-shadow:
      0 0 30px rgba(100,255,218,0.25);
    }

    .cta-btn:active{
      transform:scale(.98);
    }

    /* GRID */

    .grid-two{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
      gap:2rem;
      align-items:center;
    }

    .icon-box{
      display:flex;
      justify-content:center;
      align-items:center;

      font-size:7rem;
      color:var(--cyan);
    }

    /* CARDS */

    .cards{
      margin-top:2rem;

      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
      gap:1.5rem;
    }

    .card{
      background:var(--card);

      border-radius:24px;
      border:1px solid var(--border);

      padding:1.5rem;

      backdrop-filter:blur(14px);

      transition:.3s ease;

      box-shadow:
      0 8px 30px rgba(0,0,0,0.25);
    }

    .card:hover{
      transform:translateY(-4px);

      box-shadow:
      0 0 30px rgba(100,255,218,0.18);
    }

    .card h3{
      color:var(--cyan);
      margin-bottom:.8rem;
    }

    /* CANCHA */

    .court-wrapper{
      margin-top:2rem;

      background:var(--card);

      border-radius:24px;
      border:1px solid var(--border);

      padding:1rem;

      overflow:hidden;
    }

    svg{
      width:100%;
      height:auto;
    }

    /* QUIZ */

    .quiz{
      display:grid;
      gap:2rem;
      margin-top:2rem;
    }

    .question{
      background:
      linear-gradient(
      135deg,
      rgba(255,255,255,0.06),
      rgba(100,255,218,0.08)
      );

      border-radius:24px;
      border:1px solid var(--border);

      padding:1.5rem;
    }

    .answers{
      display:grid;
      gap:1rem;
      margin-top:1.5rem;
    }

    .answer{
      border:none;
      border-radius:18px;

      padding:1rem;

      font-size:1rem;
      font-weight:700;

      color:white;

      cursor:pointer;

      transition:.25s ease;

      box-shadow:
      0 8px 18px rgba(0,0,0,0.25);
    }

    .answer:hover{
      transform:translateY(-4px) scale(1.02);
    }

    .answer:active{
      transform:scale(.98);
    }

    /* COLORES */

    .blue{
      background:
      linear-gradient(135deg,#00C6FF,#0072FF);
    }

    .pink{
      background:
      linear-gradient(135deg,#FF4E9B,#FF006E);
    }

    .yellow{
      background:
      linear-gradient(135deg,#FFD93D,#FFB703);
      color:#1b1b1b;
    }

    .green{
      background:
      linear-gradient(135deg,#00C853,#64DD17);
    }

    .orange{
      background:
      linear-gradient(135deg,#FF9800,#FF5722);
    }

    .purple{
      background:
      linear-gradient(135deg,#7C4DFF,#651FFF);
    }

    .feedback{
      margin-top:1rem;
      font-weight:800;
      font-size:1rem;
    }

    .feedback.error{
      color:var(--danger);
    }

    /* TOAST */

    .toast{
      position:fixed;

      left:50%;
      bottom:20px;

      transform:translateX(-50%);

      background:rgba(17,34,64,0.95);

      border:1px solid var(--cyan);
      border-radius:16px;

      padding:1rem 1.5rem;

      color:var(--text);

      backdrop-filter:blur(12px);

      z-index:1000;

      animation:pulse 2s infinite;
    }

    .toast strong{
      color:var(--cyan);
    }

    @keyframes pulse{
      0%,100%{
        transform:translateX(-50%) scale(1);
      }

      50%{
        transform:translateX(-50%) scale(1.02);
      }
    }

    /* FOOTER */

    .app-footer{
      text-align:center;
      padding:2rem;
      border-top:1px solid #233554;
      margin-top:3rem;
      color:#8892B0;
      font-size:.9rem;
    }

    /* REDUCED MOTION */

    @media(prefers-reduced-motion:reduce){

      *{
        animation:none !important;
        transition:none !important;
        scroll-behavior:auto !important;
      }

    }

  </style>
</head>

